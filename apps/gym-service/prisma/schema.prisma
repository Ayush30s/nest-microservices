generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////
// ENUMS
///////////////////////////

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum PaymentMethod {
  CASH
  UPI
}

enum PaymentStatus {
  SUCCESS
  PENDING 
  FAILED 
  REFUNDED
}

///////////////////////////
// GYM
///////////////////////////

model Gym {
  id Int @id @default(autoincrement())
  
  name String 
  description String?

  ownerId     Int

  maxMembers  Int?
  isPrivate   Boolean  @default(false)

  memberships Membership[]
  classes     GymClass[]
  attendance  Attendance[]
  trainerGyms TrainerGym[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId]) 
  @@map("gyms")
}

// Since your users table is handled by an external User Service,
// all user_id and trainer_id fields are treated as external references.

//////////////////////////////////////////////////////////////
// 1. membership_plans Table
//////////////////////////////////////////////////////////////
// Purpose: Stores the different pricing packages the gym offers to its members.
//
// id: Primary Key — Unique identifier for this plan.
// name: Display name of the package (e.g., Monthly, Annual).
// description: Details of benefits.
// price: Cost of the plan.
// durationInDays: Validity duration.
// createdAt: When the plan was created.

model Membership {
  id  Int @id @default(autoincrement())
  
  gymId Int            
  gym   Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  name String 
  description String

  price Int
  durationInDays Int

  subscriptions Subscription[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////////////
// 2. subscriptions Table
//////////////////////////////////////////////////////////////
// Purpose: Links a user to a membership plan.
//
// id: Unique subscription ID.
// userId: External user ID.
// planId: Membership plan.
// startDate: Start of access.
// endDate: Expiry date.
// status: ACTIVE, EXPIRED, etc.
// createdAt: When subscription was created.

model Subscription {
  id Int @id @default(autoincrement())

  userId Int
  
  planId Int
  plan Membership @relation(fields: [planId], references: [id])

  startDate DateTime @default(now()) 
  endDate DateTime

  status SubscriptionStatus @default(PENDING)

  createdAt DateTime @default(now())

  payments Payment[]
}

//////////////////////////////////////////////////////////////
// 3. classes Table
//////////////////////////////////////////////////////////////
// Purpose: Stores group workout sessions.
//
// id: Unique class ID.
// title: Class name.
// description: Details.
// trainerId: Trainer conducting the class.
// startTime / endTime: Schedule.
// maxCapacity: Maximum members.

model GymClass {
  id Int @id @default(autoincrement())

  gymId Int
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  trainerPk Int
  trainer Trainer @relation(fields: [trainerPk], references: [id])

  title String
  description String

  startTime DateTime
  endTime DateTime
  
  maxCapacity Int

  createdAt DateTime @default(now())

  bookings ClassBooking[]

  @@map("gym_classes")
}

//////////////////////////////////////////////////////////////
// 4. class_bookings Table
//////////////////////////////////////////////////////////////
// Purpose: Tracks which users booked which classes.
//
// id: Booking ID.
// classId: Class being booked.
// userId: User booking.
// bookingStatus: CONFIRMED, CANCELLED, ATTENDED.
// createdAt: Booking time.

model ClassBooking {
  id Int @id @default(autoincrement())

  classId Int
  gymClass GymClass @relation(fields: [classId], references: [id])

  userId Int

  bookingStatus BookingStatus
  
  createdAt DateTime @default(now())

  @@unique([classId, userId])
}

//////////////////////////////////////////////////////////////
// 5. attendance Table
//////////////////////////////////////////////////////////////
// Purpose: Logs entry/exit of users.
//
// id: Visit ID.
// userId: Who entered.
// gymId: Which gym.
// checkInTime: Entry time.
// checkOutTime: Exit time.

model Attendance {
  id Int @id @default(autoincrement())

  gymId Int
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  userId Int

  checkInTime DateTime @default(now())
  checkOutTime DateTime?

  @@index([gymId])
  @@index([userId])
  @@map("attendance")
}

//////////////////////////////////////////////////////////////
// 6. payments Table
//////////////////////////////////////////////////////////////
// Purpose: Logs all financial transactions.
//
// id: Payment ID.
// userId: Who paid.
// subscriptionId: Linked subscription (optional).
// amount: Paid amount.
// paymentMethod: CASH / UPI.
// paymentStatus: SUCCESS, FAILED, etc.
// transactionDate: Time of payment.

model Payment {
  id Int @id @default(autoincrement())

  userId Int

  subscriptionId Int?
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  amount Int

  paymentMethod PaymentMethod
  paymentStatus PaymentStatus

  transactionDate DateTime @default(now())
}

//////////////////////////////////////////////////////////////
// 7. trainer_profiles Table
//////////////////////////////////////////////////////////////
// Purpose: Stores trainer-specific info.
//
// trainerId: External user ID.
// specialization: Trainer expertise.
// bio: Description.
// hourlyRate: Cost per session.

model Trainer {
  id Int @id @default(autoincrement())
  
  trainerId Int @unique

  specialization String
  bio String
  hourlyRate Int
  
  trainerGyms TrainerGym[]
  classes GymClass[]
}

//////////////////////////////////////////////////////////////
// Trainer-Gym Join Table
//////////////////////////////////////////////////////////////
// Purpose: Many-to-many relation between trainers and gyms.
//
// A trainer can work in multiple gyms.
// A gym can have multiple trainers.

model TrainerGym {
  id Int @id @default(autoincrement())

  trainerPk Int
  gymId Int

  trainer Trainer @relation(fields: [trainerPk], references: [id], onDelete: Cascade)
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([trainerPk, gymId])
}