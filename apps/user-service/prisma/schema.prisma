generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-clients/user"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TRAINER
}

model User {
  id              Int           @id @default(autoincrement())
  email           String        @unique
  name            String?
  passwordHash    String
  role            Role          @default(USER)
  isActive        Boolean?      @default(true)
  isEmailVerified Boolean?      @default(false)
  lastLoginAt     DateTime?     @default(now())
  created_at      DateTime      @default(now())
  updated_at      DateTime?
  address         Address?
  profile         Profile?
  userSession     UserSession?
  userFollower    UserFollows[] @relation("FollowerRelation")
  userFollowing   UserFollows[] @relation("FollowingRelation")
}

model Address {
  id      Int    @id @default(autoincrement())
  state   String
  city    String
  pincode String

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Profile {
  id              Int       @id @default(autoincrement())
  gender          String
  dob             DateTime
  heightCm        Int
  weightKg        Int
  profileImageUrl String
  address         String
  bio             String
  contact_no      String
  created_at      DateTime  @default(now())
  updated_at      DateTime?

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model UserSession {
  id               Int      @id @default(autoincrement())
  apAddress        String
  device           String
  platform         String
  refreshTokenHash String
  expiresAt        DateTime
  created_at       DateTime @default(now())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model UserFollows {
  id Int @id @default(autoincrement())

  followerId   Int
  followerUser User @relation("FollowerRelation", fields: [followerId], references: [id])

  followingId   Int
  followingUser User @relation("FollowingRelation", fields: [followingId], references: [id])

  created_at DateTime @default(now())
}