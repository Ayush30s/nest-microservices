generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-clients/user"
}

datasource db {
  provider = "postgresql"
  url      = env("USER_DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  authId        Int      @unique // Important: Maps to 'id' in the Auth Service!
  email         String   @unique
  slug          String? 
  name          String?

  address       Address?
  profile       Profile?
  
  userFollower  UserFollows[]  @relation("FollowerRelation")
  userFollowing UserFollows[]  @relation("FollowingRelation")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model Address {
  id      Int    @id @default(autoincrement())
  state   String
  city    String
  pincode String

  userId  Int    @unique
  user    User   @relation(fields: [userId], references: [id])

  @@map("addresses")
}

model Profile {
  id              Int       @id @default(autoincrement())
  gender          String
  dob             DateTime
  heightCm        Int
  weightKg        Int
  profileImageUrl String?  
  address         String    // (Note: You also have an Address model, you might want to remove this string field to avoid duplication)
  bio             String?
  contact_no      String?
  
  userId          Int       @unique
  user            User      @relation(fields: [userId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("profiles")
}

model UserFollows {
  id            Int      @id @default(autoincrement())

  followerId    Int
  followerUser  User     @relation("FollowerRelation", fields: [followerId], references: [id])

  followingId   Int
  followingUser User     @relation("FollowingRelation", fields: [followingId], references: [id])

  createdAt     DateTime @default(now())

  @@map("user_follows")
}